# Daily Rep — required environment variables.
# Copy to .env.local and fill in real values. .env.local is gitignored; NEVER commit real keys.
#
# An account is REQUIRED to use the app, so BOTH of these must be set in any production build —
# the build/startup fails fast (src/lib/supabase.ts) if either is missing in production.

# Your Supabase project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The Supabase "anon" / publishable key (safe in the client — protected by Row-Level Security).
# Do NOT use the service_role key here; it must never ship to the client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL — Cloudflare Turnstile (CAPTCHA) site key for bot protection on sign-up / sign-in.
# When set, the Auth screen renders the Turnstile widget and requires a token. Leave BLANK to disable
# (dev/preview behave exactly as before). The matching SECRET key must ALSO be configured in the
# Supabase dashboard (Auth → Attack Protection → enable CAPTCHA = Turnstile) so the server verifies it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# OPTIONAL — Sentry error tracking (org "daily-reps", project "daily-reps"). When the DSN is set in a
# PRODUCTION build, client/server/edge errors and the app's reportError() seam ship to Sentry; blank =
# disabled (dev/preview unaffected). Find the DSN in Sentry → Project Settings → Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Build-time ONLY (set in the CI/host env, do NOT commit): uploads source maps for readable stack traces.
# Create at Sentry → Settings → Auth Tokens (project:releases scope). Builds still succeed without it.
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe billing (subscriptions). The browser NEVER talks to Stripe directly — checkout and the billing
# portal are Stripe-hosted redirects created by Supabase Edge Functions — so there is NO Stripe key in
# this file and NO publishable key in the client. All Stripe secrets live in the Supabase project's
# Edge Function secrets (Dashboard → Project Settings → Edge Functions → Secrets, or `supabase secrets set`):
#
#   STRIPE_SECRET_KEY        = sk_test_…   (your Stripe secret key; required)
#   STRIPE_WEBHOOK_SECRET    = whsec_…     (signing secret of the stripe-webhook endpoint; required)
#   STRIPE_PRICE_MONTHLY     = price_…     (optional override; test default is baked into the function)
#   STRIPE_PRICE_ANNUAL      = price_…     (optional override)
#   STRIPE_PORTAL_CONFIG     = bpc_…       (optional billing-portal configuration override)
#   APP_URL                  = https://daily-rep.app   (optional; checkout return URLs. Falls back to the
#                                                        request Origin, so it's not needed for local dev.)
#
# See docs/STRIPE_SETUP.md for the full provisioning + go-live runbook.
#
# ─────────────────────────────────────────────────────────────────────────────
# Reconciliation cron secret (missed-webhook safety net). The `reconcile-subscriptions` Edge Function is
# public (no Supabase JWT — pg_cron/pg_net invokes it server-to-server) and authenticates via a shared
# secret header `x-reconcile-secret`. Set it as an Edge Function secret AND mirror the SAME value into
# Vault so the cron job (migration 20260626160000) can send it. They MUST match.
#
#   RECONCILE_SECRET         = <random>    (Edge Function secret; e.g. `openssl rand -hex 32`)
#
# Then, in the SQL editor / psql (stores it encrypted so it's never committed):
#   select vault.create_secret('https://<ref>.supabase.co/functions/v1/reconcile-subscriptions', 'reconcile_url');
#   select vault.create_secret('<same RECONCILE_SECRET>', 'reconcile_secret');
